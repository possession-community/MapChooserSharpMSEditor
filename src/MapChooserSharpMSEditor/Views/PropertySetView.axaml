<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vme="using:MapChooserSharpMSEditor.ViewModels.Editors"
             xmlns:models="using:MapChooserSharpMSEditor.Models"
             xmlns:sys="using:System"
             xmlns:l="using:MapChooserSharpMSEditor.Services"
             xmlns:views="using:MapChooserSharpMSEditor.Views"
             x:Class="MapChooserSharpMSEditor.Views.PropertySetView"
             x:DataType="vme:PropertySetViewModel">
    <UserControl.Resources>
        <views:CollectionJoinConverter x:Key="Join" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock.sectionHeader">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#9cdcfe" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>
        <!-- "?" icon that sits next to a property label. Tooltip text lives in the
             localization catalog under Prop.Xxx.Desc so adding a new property just means
             one more .Desc key, no style change. -->
        <Style Selector="TextBlock.helpIcon">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#7a7a7a" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Help" />
        </Style>
        <Style Selector="TextBlock.helpIcon:pointerover">
            <Setter Property="Foreground" Value="#9cdcfe" />
        </Style>
        <Style Selector="Border.propRow">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="#252525" />
        </Style>
        <Style Selector="Border.propRow.hasOverride">
            <Setter Property="Background" Value="#2a3148" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.usingDefault">
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Each row shares the same 4-column layout: label | editor | status | action -->
        <Style Selector="TextBlock.propLabel">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- Day-of-week chips: the checked state gets a distinct blue so a glance tells
             the user which days are currently in the allow-list. Hover and border tweaks
             match the rest of the dark theme. -->
        <Style Selector="ToggleButton.dayChip:checked">
            <Setter Property="Background" Value="#2a5fa8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#3c7bd4" />
        </Style>
        <Style Selector="ToggleButton.dayChip:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3470c8" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="4">

        <TextBlock Text="{l:Localize Section.Basic}" Classes="sectionHeader" />

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMapNameAlias}" IsVisible="{Binding ShowMapNameAlias}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MapNameAlias.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MapNameAlias}" />
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding Model.MapNameAlias}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMapNameAlias}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}"
                        Command="{Binding ClearOverrideCommand}" CommandParameter="MapNameAlias"
                        IsVisible="{Binding Model.HasMapNameAlias}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMapDescription}" IsVisible="{Binding ShowMapDescription}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MapDescription.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MapDescription}" />
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding Model.MapDescription}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMapDescription}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}"
                        Command="{Binding ClearOverrideCommand}" CommandParameter="MapDescription"
                        IsVisible="{Binding Model.HasMapDescription}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasWorkshopId}" IsVisible="{Binding ShowWorkshopId}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.WorkshopId.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.WorkshopId}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.WorkshopId}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasWorkshopId}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="WorkshopId"
                        IsVisible="{Binding Model.HasWorkshopId}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasIsDisabled}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.IsDisabled.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.IsDisabled}" />
                </StackPanel>
                <CheckBox Grid.Column="1" IsChecked="{Binding Model.IsDisabled}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasIsDisabled}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="IsDisabled"
                        IsVisible="{Binding Model.HasIsDisabled}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasGroupSettings}" IsVisible="{Binding ShowGroupSettings}">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="220,*,130,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.GroupSettings.Desc}" />
                        <TextBlock Classes="propLabel" Text="{l:Localize Prop.GroupSettings}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <AutoCompleteBox Width="220"
                                         Text="{Binding NewGroupName, Mode=TwoWay}"
                                         ItemsSource="{Binding Project.AllGroupNames}"
                                         FilterMode="ContainsOrdinal"
                                         Watermark="{l:Localize Watermark.GroupName}"
                                         MinimumPrefixLength="0" />
                        <Button Content="{l:Localize Button.Add}" Command="{Binding AddGroupReferenceCommand}" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{l:Localize Status.NoInheritance}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasGroupSettings}" />
                    <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.ResetAll}" ToolTip.Tip="{l:Localize Tip.ResetAll}"
                            Command="{Binding ClearOverrideCommand}" CommandParameter="GroupSettings"
                            IsVisible="{Binding Model.HasGroupSettings}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding GroupReferences}" Margin="24,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vme:GroupRefViewModel">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,2"
                                  Background="#00000001"
                                  DragDrop.AllowDrop="True"
                                  DragDrop.DragOver="OnGroupRefDragOver"
                                  DragDrop.Drop="OnGroupRefDrop">
                                <!-- Drag handle: only this element starts a drag -->
                                <Border Grid.Column="0" Padding="6,2" Cursor="SizeAll"
                                        Background="#00000001"
                                        ToolTip.Tip="Drag to reorder"
                                        PointerPressed="OnGroupRefPointerPressed">
                                    <TextBlock Text="☰" FontSize="14" Foreground="#888" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="&#xE7BA;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           Foreground="#f0a33d" Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           ToolTip.Tip="{l:Localize Tip.UnknownGroup}"
                                           IsVisible="{Binding !IsKnown}" />
                                <!-- Unknown group refs get red text in addition to the
                                     warning icon so they read as "broken" at a glance.
                                     Server would silently skip these, which is easy to
                                     miss without a visual cue. -->
                                <TextBlock Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center"
                                           ToolTip.Tip="{Binding IsKnown, Converter={x:Static views:UnknownGroupTipConverter.Instance}}"
                                           Foreground="{Binding IsKnown, Converter={x:Static views:UnknownGroupBrushConverter.Instance}}" />
                                <Button Grid.Column="3" Content="×" Padding="6,2"
                                        Command="{Binding $parent[ItemsControl].((vme:PropertySetViewModel)DataContext).RemoveGroupReferenceCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasSearchTags}" IsVisible="{Binding ShowSearchTags}">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="220,*,130,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.SearchTags.Desc}" />
                        <TextBlock Classes="propLabel" Text="{l:Localize Prop.SearchTags}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <TextBox Width="220" Text="{Binding NewSearchTag}" Watermark="{l:Localize Watermark.SearchTag}" />
                        <Button Content="{l:Localize Button.Add}" Command="{Binding AddSearchTagCommand}" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasSearchTags}" />
                    <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.ResetAll}" ToolTip.Tip="{l:Localize Tip.ResetAll}"
                            Command="{Binding ClearOverrideCommand}" CommandParameter="SearchTags"
                            IsVisible="{Binding Model.HasSearchTags}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Model.SearchTags}" Margin="24,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="×" Padding="6,2"
                                        Command="{Binding $parent[ItemsControl].((vme:PropertySetViewModel)DataContext).RemoveSearchTagCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasCooldownOverride}" IsVisible="{Binding ShowCooldownOverride}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.CooldownOverride.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.CooldownOverride}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.CooldownOverride}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{l:Localize Status.NoOverride}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasCooldownOverride}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="CooldownOverride"
                        IsVisible="{Binding Model.HasCooldownOverride}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasShortGroupName}" IsVisible="{Binding ShowShortGroupName}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.ShortGroupName.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.ShortGroupName}" />
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding Model.ShortGroupName}" MaxLength="4" Watermark="{l:Localize Watermark.ShortGroupName}" />
                <TextBlock Grid.Column="2" Text="{l:Localize Status.NoOverride}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasShortGroupName}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="ShortGroupName"
                        IsVisible="{Binding Model.HasShortGroupName}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasNominationLimit}" IsVisible="{Binding ShowNominationLimit}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.NominationLimit.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.NominationLimit}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.NominationLimit}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{l:Localize Status.NoOverride}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasNominationLimit}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="NominationLimit"
                        IsVisible="{Binding Model.HasNominationLimit}" />
            </Grid>
        </Border>

        <TextBlock Text="{l:Localize Section.ExtendTime}" Classes="sectionHeader" />

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMaxExtends}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MaxExtends.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MaxExtends}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.MaxExtends}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMaxExtends}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="MaxExtends"
                        IsVisible="{Binding Model.HasMaxExtends}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMaxExtCommandUses}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MaxExtCommandUses.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MaxExtCommandUses}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.MaxExtCommandUses}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMaxExtCommandUses}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="MaxExtCommandUses"
                        IsVisible="{Binding Model.HasMaxExtCommandUses}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasExtendTimePerExtends}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.ExtendTimePerExtends.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.ExtendTimePerExtends}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.ExtendTimePerExtends}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasExtendTimePerExtends}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="ExtendTimePerExtends"
                        IsVisible="{Binding Model.HasExtendTimePerExtends}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMapTime}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MapTime.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MapTime}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.MapTime}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMapTime}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="MapTime"
                        IsVisible="{Binding Model.HasMapTime}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasExtendRoundsPerExtends}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.ExtendRoundsPerExtends.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.ExtendRoundsPerExtends}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.ExtendRoundsPerExtends}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasExtendRoundsPerExtends}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="ExtendRoundsPerExtends"
                        IsVisible="{Binding Model.HasExtendRoundsPerExtends}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMapRounds}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MapRounds.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MapRounds}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.MapRounds}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMapRounds}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="MapRounds"
                        IsVisible="{Binding Model.HasMapRounds}" />
            </Grid>
        </Border>

        <TextBlock Text="{l:Localize Section.Nomination}" Classes="sectionHeader" />

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMapSelectionWeight}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MapSelectionWeight.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MapSelectionWeight}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.MapSelectionWeight}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMapSelectionWeight}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="MapSelectionWeight"
                        IsVisible="{Binding Model.HasMapSelectionWeight}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasOnlyNomination}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.OnlyNomination.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.OnlyNomination}" />
                </StackPanel>
                <CheckBox Grid.Column="1" IsChecked="{Binding Model.OnlyNomination}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasOnlyNomination}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="OnlyNomination"
                        IsVisible="{Binding Model.HasOnlyNomination}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMaxPlayers}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MaxPlayers.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MaxPlayers}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.MaxPlayers}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMaxPlayers}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="MaxPlayers"
                        IsVisible="{Binding Model.HasMaxPlayers}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasMinPlayers}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.MinPlayers.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.MinPlayers}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.MinPlayers}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasMinPlayers}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="MinPlayers"
                        IsVisible="{Binding Model.HasMinPlayers}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasProhibitAdminNomination}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.ProhibitAdminNomination.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.ProhibitAdminNomination}" />
                </StackPanel>
                <CheckBox Grid.Column="1" IsChecked="{Binding Model.ProhibitAdminNomination}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasProhibitAdminNomination}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="ProhibitAdminNomination"
                        IsVisible="{Binding Model.HasProhibitAdminNomination}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasRestrictToAllowedUsersOnly}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.RestrictToAllowedUsersOnly.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.RestrictToAllowedUsersOnly}" />
                </StackPanel>
                <CheckBox Grid.Column="1" IsChecked="{Binding Model.RestrictToAllowedUsersOnly}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasRestrictToAllowedUsersOnly}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="RestrictToAllowedUsersOnly"
                        IsVisible="{Binding Model.HasRestrictToAllowedUsersOnly}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasDaysAllowed}">
            <StackPanel Spacing="4">
                <Grid ColumnDefinitions="220,*,130,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.DaysAllowed.Desc}" />
                        <TextBlock Classes="propLabel" Text="{l:Localize Prop.DaysAllowed}" />
                    </StackPanel>
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding DaysAllowedToggles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vme:DayToggleViewModel">
                                <!-- "dayChip" picks up the :checked brush override defined
                                     in the style block below, so selected days render
                                     blue at a glance. -->
                                <ToggleButton Classes="dayChip" Content="{Binding Day}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,0,4,4" MinWidth="90" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasDaysAllowed}" />
                    <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.ResetAll}" ToolTip.Tip="{l:Localize Tip.ResetAll}"
                            Command="{Binding ClearOverrideCommand}" CommandParameter="DaysAllowed"
                            IsVisible="{Binding Model.HasDaysAllowed}" />
                </Grid>
                <TextBlock Margin="0,0,0,0" Foreground="#888" IsVisible="{Binding Model.HasDaysAllowed}"
                           Text="{Binding Model.DaysAllowed, Converter={StaticResource Join}, StringFormat='selected: {0}'}" />
            </StackPanel>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasAllowedTimeRanges}">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="220,*,130,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.AllowedTimeRanges.Desc}" />
                        <TextBlock Classes="propLabel" Text="{l:Localize Prop.AllowedTimeRanges}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <TextBox Text="{Binding NewTimeRange}" Width="160" Watermark="{l:Localize Watermark.TimeRange}"
                                 ToolTip.Tip="{Binding IsNewTimeRangeValid, Converter={x:Static views:InvalidTimeRangeTipConverter.Instance}}"
                                 BorderBrush="{Binding IsNewTimeRangeValid, Converter={x:Static views:InvalidInputBrushConverter.Instance}}" />
                        <Button Content="{l:Localize Button.Add}" Command="{Binding AddTimeRangeCommand}" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasAllowedTimeRanges}" />
                    <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.ResetAll}" ToolTip.Tip="{l:Localize Tip.ResetAll}"
                            Command="{Binding ClearOverrideCommand}" CommandParameter="AllowedTimeRanges"
                            IsVisible="{Binding Model.HasAllowedTimeRanges}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Model.AllowedTimeRanges}" Margin="24,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:TimeRangeSpec">
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2"
                                  Background="#00000001"
                                  DragDrop.AllowDrop="True"
                                  DragDrop.DragOver="OnTimeRangeDragOver"
                                  DragDrop.Drop="OnTimeRangeDrop">
                                <Border Grid.Column="0" Padding="6,2" Cursor="SizeAll"
                                        Background="#00000001"
                                        ToolTip.Tip="Drag to reorder"
                                        PointerPressed="OnTimeRangePointerPressed">
                                    <TextBlock Text="☰" FontSize="14" Foreground="#888" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" />
                                <Button Grid.Column="2" Content="×" Padding="6,2"
                                        Command="{Binding $parent[ItemsControl].((vme:PropertySetViewModel)DataContext).RemoveTimeRangeCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <TextBlock Text="{l:Localize Section.Cooldown}" Classes="sectionHeader" />

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasCooldown}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.Cooldown.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.Cooldown}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.Cooldown}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasCooldown}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="Cooldown"
                        IsVisible="{Binding Model.HasCooldown}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasCooldownDateTime}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.CooldownDateTime.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.CooldownDateTime}" />
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding Model.CooldownDateTime}" Watermark="{l:Localize Watermark.CooldownDateTime}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasCooldownDateTime}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="CooldownDateTime"
                        IsVisible="{Binding Model.HasCooldownDateTime}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasNominationCooldown}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.NominationCooldown.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.NominationCooldown}" />
                </StackPanel>
                <NumericUpDown Grid.Column="1" Value="{Binding Model.NominationCooldown}" FormatString="0" Minimum="0" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasNominationCooldown}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="NominationCooldown"
                        IsVisible="{Binding Model.HasNominationCooldown}" />
            </Grid>
        </Border>

        <Border Classes="propRow" Classes.hasOverride="{Binding Model.HasNominationCooldownDateTime}">
            <Grid ColumnDefinitions="220,*,130,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="helpIcon" Text="&#xE946;" ToolTip.Tip="{l:Localize Prop.NominationCooldownDateTime.Desc}" />
                    <TextBlock Classes="propLabel" Text="{l:Localize Prop.NominationCooldownDateTime}" />
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding Model.NominationCooldownDateTime}" Watermark="{l:Localize Watermark.CooldownDateTime}" />
                <TextBlock Grid.Column="2" Text="{Binding InheritedStatusText}" Classes="usingDefault" Margin="8,0" IsVisible="{Binding !Model.HasNominationCooldownDateTime}" />
                <Button Grid.Column="3" Classes="action" Content="{l:Localize Button.Reset}" ToolTip.Tip="{l:Localize Tip.Reset}" Command="{Binding ClearOverrideCommand}" CommandParameter="NominationCooldownDateTime"
                        IsVisible="{Binding Model.HasNominationCooldownDateTime}" />
            </Grid>
        </Border>

        <TextBlock Text="{l:Localize Section.Extra}" Classes="sectionHeader" />
        <Border Classes="propRow">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBox Text="{Binding NewExtraSectionName}" Width="220" Watermark="{l:Localize Watermark.SectionName}" />
                    <Button Content="{l:Localize Button.AddSection}" Command="{Binding AddExtraSectionCommand}" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding Model.Extras}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:ExtraSection">
                            <Border Background="#1e1e1e" Padding="8" Margin="0,4" CornerRadius="4">
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Text="{l:Localize Extra.Prefix}" VerticalAlignment="Center" Foreground="#888" />
                                        <TextBox Grid.Column="1" Text="{Binding Name}" />
                                        <Button Grid.Column="2" Content="{l:Localize Button.RemoveSection}" Margin="6,0,0,0"
                                                Command="{Binding $parent[ItemsControl].((vme:PropertySetViewModel)DataContext).RemoveExtraSectionCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Entries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="models:ExtraKeyValue">
                                                <Grid ColumnDefinitions="180,120,*,Auto" Margin="0,2">
                                                    <TextBox Text="{Binding Key}" Watermark="{l:Localize Watermark.ExtraKey}" />
                                                    <ComboBox Grid.Column="1" Margin="4,0"
                                                              SelectedItem="{Binding Kind}">
                                                        <models:ExtraValueKind>String</models:ExtraValueKind>
                                                        <models:ExtraValueKind>Integer</models:ExtraValueKind>
                                                        <models:ExtraValueKind>Float</models:ExtraValueKind>
                                                        <models:ExtraValueKind>Boolean</models:ExtraValueKind>
                                                    </ComboBox>
                                                    <TextBox Grid.Column="2" Text="{Binding Value}" Watermark="{l:Localize Watermark.ExtraValue}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="{l:Localize Button.AddKey}" HorizontalAlignment="Left"
                                            Command="{Binding $parent[ItemsControl].((vme:PropertySetViewModel)DataContext).AddExtraKeyCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
