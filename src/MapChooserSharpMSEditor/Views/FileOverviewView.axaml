<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vme="using:MapChooserSharpMSEditor.ViewModels.Editors"
             xmlns:models="using:MapChooserSharpMSEditor.Models"
             x:Class="MapChooserSharpMSEditor.Views.FileOverviewView"
             x:DataType="vme:FileOverviewViewModel">
    <UserControl.Styles>
        <Style Selector="Button.entry">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="&#xE8A5;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                       FontSize="22" Foreground="#7aa2f7" VerticalAlignment="Center" />
            <TextBlock Text="{Binding File.DisplayName}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="Open Default Settings" Margin="12,0,0,0" Command="{Binding OpenDefaultCommand}" />
        </StackPanel>

        <TextBox Watermark="Filter groups and maps..." Text="{Binding Filter, Mode=TwoWay}" Width="360" HorizontalAlignment="Left" />

        <!-- Groups -->
        <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#9cdcfe" Text="{Binding File.Groups.Count, StringFormat='Groups ({0})'}" />
            <Border Background="#1e1e1e" Padding="10" CornerRadius="4">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding FilteredGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:GroupEntryModel">
                                <Button Classes="entry"
                                        Command="{Binding $parent[ItemsControl].((vme:FileOverviewViewModel)DataContext).OpenGroupCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                   Foreground="#7aa2f7" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding GroupName}" FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center" />
                                        <TextBlock Foreground="#888" FontSize="11" VerticalAlignment="Center"
                                                   Text="{Binding DaySettings.Count, StringFormat='{}{0} day-settings'}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="(no groups)" Foreground="#666" FontStyle="Italic"
                               IsVisible="{Binding !FilteredGroups.Count}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Maps -->
        <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#9cdcfe" Text="{Binding File.Maps.Count, StringFormat='Maps ({0})'}" />
            <Border Background="#1e1e1e" Padding="10" CornerRadius="4">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding FilteredMaps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:MapEntryModel">
                                <Button Classes="entry"
                                        Command="{Binding $parent[ItemsControl].((vme:FileOverviewViewModel)DataContext).OpenMapCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="&#xE707;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                   Foreground="#7aa2f7" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding MapName}" FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center" />
                                        <TextBlock Foreground="#888" FontSize="11" VerticalAlignment="Center"
                                                   Text="{Binding Properties.MapNameAlias, StringFormat='“{0}”'}"
                                                   IsVisible="{Binding Properties.HasMapNameAlias}" />
                                        <TextBlock Foreground="#888" FontSize="11" VerticalAlignment="Center"
                                                   Text="{Binding DaySettings.Count, StringFormat='{}{0} day-settings'}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="(no maps)" Foreground="#666" FontStyle="Italic"
                               IsVisible="{Binding !FilteredMaps.Count}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
