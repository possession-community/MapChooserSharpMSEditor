<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vme="using:MapChooserSharpMSEditor.ViewModels.Editors"
             xmlns:models="using:MapChooserSharpMSEditor.Models"
             xmlns:views="using:MapChooserSharpMSEditor.Views"
             x:Class="MapChooserSharpMSEditor.Views.GroupEditorView"
             x:DataType="vme:GroupEditorViewModel">
    <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                       FontSize="22" Foreground="#7aa2f7" VerticalAlignment="Center" />
            <TextBlock Text="Group:" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBox Text="{Binding Group.GroupName}" Width="320" VerticalAlignment="Center" FontFamily="Cascadia Mono,Consolas" />
        </StackPanel>
        <TextBlock Text="{Binding File.DisplayName, StringFormat='File: {0}'}" Foreground="#888" />
        <Separator />
        <views:PropertySetView DataContext="{Binding Properties}" />

        <TextBlock Text="DaySettings Overrides (applies to all maps referencing this group)"
                   FontSize="14" FontWeight="SemiBold" Foreground="#9cdcfe" Margin="0,16,0,6" />
        <Button Content="+ Add Override" HorizontalAlignment="Left" Command="{Binding AddDaySettingsCommand}" />
        <ItemsControl ItemsSource="{Binding Group.DaySettings}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:DaySettingsOverrideModel">
                    <Border Background="#252525" Padding="8" Margin="0,4" CornerRadius="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Foreground="#888" FontSize="12"
                                           Text="{Binding TargetDays, StringFormat='Days: {0}'}" />
                                <TextBlock Foreground="#888" FontSize="12"
                                           Text="{Binding TargetTimeRanges, StringFormat='Times: {0}'}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Remove" VerticalAlignment="Top"
                                    Command="{Binding $parent[ItemsControl].((vme:GroupEditorViewModel)DataContext).RemoveDaySettingsCommand}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
