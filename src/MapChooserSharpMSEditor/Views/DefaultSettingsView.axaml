<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vme="using:MapChooserSharpMSEditor.ViewModels.Editors"
             xmlns:views="using:MapChooserSharpMSEditor.Views"
             x:Class="MapChooserSharpMSEditor.Views.DefaultSettingsView"
             x:DataType="vme:DefaultSettingsViewModel">
    <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                       FontSize="22" Foreground="#7aa2f7" VerticalAlignment="Center" />
            <TextBlock Text="Default Settings" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="[MapChooserSharpSettings.Default]" Foreground="#888" FontFamily="Cascadia Mono,Consolas"
                       VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="{Binding File.DisplayName, StringFormat='File: {0}'}" Foreground="#888" />
        <Separator />
        <views:PropertySetView DataContext="{Binding Properties}" />
    </StackPanel>
</UserControl>
