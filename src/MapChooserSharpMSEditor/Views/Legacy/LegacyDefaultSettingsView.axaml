<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmel="using:MapChooserSharpMSEditor.ViewModels.Editors.Legacy"
             xmlns:mlegacy="using:MapChooserSharpMSEditor.Models.Legacy"
             xmlns:views="using:MapChooserSharpMSEditor.Views.Legacy"
             xmlns:l="using:MapChooserSharpMSEditor.Services"
             x:Class="MapChooserSharpMSEditor.Views.Legacy.LegacyDefaultSettingsView"
             x:DataType="vmel:LegacyDefaultSettingsViewModel">
    <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                       FontSize="22" Foreground="#7aa2f7" VerticalAlignment="Center" />
            <TextBlock Text="{l:Localize Default.Title}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{l:Localize Default.Section}" Foreground="#888" FontFamily="Cascadia Mono,Consolas"
                       VerticalAlignment="Center" />
            <Border Background="#3a2e16" BorderBrush="#a87a33" BorderThickness="1" CornerRadius="3"
                    Padding="6,2" VerticalAlignment="Center">
                <TextBlock Text="LEGACY" FontSize="11" FontWeight="SemiBold" Foreground="#fdd58c" />
            </Border>
        </StackPanel>

        <Border Background="#3a1e1e" BorderBrush="#a33" BorderThickness="1" CornerRadius="3"
                Padding="10,8" IsVisible="{Binding HasMultiple}">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Default.MultipleWarning.Title}"
                           FontWeight="SemiBold" Foreground="#fbb" />
                <TextBlock Text="{l:Localize Default.MultipleWarning.Body}"
                           Foreground="#fbb" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding DefaultOwners}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="mlegacy:LegacyMapConfigFile">
                            <Grid ColumnDefinitions="*,Auto" Margin="8,2,0,2">
                                <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                           FontFamily="Cascadia Mono,Consolas" Foreground="#fdd"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="{l:Localize Default.RemoveOwner}"
                                        Padding="8,2" FontSize="12"
                                        Command="{Binding $parent[ItemsControl].((vmel:LegacyDefaultSettingsViewModel)DataContext).DetachFromFileCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <StackPanel IsVisible="{Binding HasOwner}" Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding Owner.DisplayName, StringFormat={l:Localize Default.OwnerLabel}}"
                           Foreground="#bbb" />
                <Button Content="{l:Localize Default.RemoveOwner}"
                        Command="{Binding DetachFromFileCommand}"
                        CommandParameter="{Binding Owner}"
                        Padding="8,2" FontSize="12"
                        ToolTip.Tip="{l:Localize Default.RemoveOwner.Tip}" />
            </StackPanel>
            <Separator />
            <views:LegacyPropertySetView DataContext="{Binding Properties}" />
        </StackPanel>

        <Border IsVisible="{Binding !HasOwner}"
                Background="#252525" BorderBrush="#3a3a3a" BorderThickness="1"
                CornerRadius="3" Padding="14,12">
            <StackPanel Spacing="10">
                <TextBlock Text="{l:Localize Default.NoOwner.Title}"
                           FontWeight="SemiBold" Foreground="#ddd" />
                <TextBlock Text="{l:Localize Default.NoOwner.Body}"
                           Foreground="#aaa" TextWrapping="Wrap" />
                <TextBox Text="{Binding AssignFilter, Mode=TwoWay}"
                         Watermark="{l:Localize Watermark.Filter}" HorizontalAlignment="Stretch" />
                <ItemsControl ItemsSource="{Binding FilteredFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="mlegacy:LegacyMapConfigFile">
                            <Button Margin="0,2" Padding="10,6" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding $parent[ItemsControl].((vmel:LegacyDefaultSettingsViewModel)DataContext).AssignCommand}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="{Binding DisplayName}" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
