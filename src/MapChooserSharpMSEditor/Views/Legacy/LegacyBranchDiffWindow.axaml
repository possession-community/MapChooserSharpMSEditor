<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vml="using:MapChooserSharpMSEditor.ViewModels.Legacy"
        xmlns:l="using:MapChooserSharpMSEditor.Services"
        x:Class="MapChooserSharpMSEditor.Views.Legacy.LegacyBranchDiffWindow"
        x:DataType="vml:LegacyBranchDiffViewModel"
        Title="Branch Diff (Legacy)"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="520"
        Background="#1c1c1c"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3470c8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,6" />
        </Style>
        <Style Selector="Border.diffRow">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background" Value="#1e1e1e" />
            <Setter Property="Margin" Value="0,1" />
        </Style>
        <Style Selector="Border.diffRow.differs">
            <!-- Amber highlight mirrors the LEGACY badge palette — tells the user at a
                 glance that the row's value changed between branches. -->
            <Setter Property="Background" Value="#3a2e16" />
        </Style>
        <Style Selector="TextBlock.valueCell">
            <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="TextBlock.valueCell.differs">
            <Setter Property="Foreground" Value="#fdd58c" />
        </Style>
        <Style Selector="Button.entryBtn">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.entryBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a3148" />
        </Style>

        <!-- Status-colored kind badge + key text. Palette matches the common git-diff
             convention (green = added, red = deleted, amber = modified). -->
        <Style Selector="Border.kindBadge">
            <Setter Property="Background" Value="#2a3148" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.kindBadge.added">        <Setter Property="Background" Value="#1e3a22" /></Style>
        <Style Selector="Border.kindBadge.deleted">      <Setter Property="Background" Value="#3a1e1e" /></Style>
        <Style Selector="Border.kindBadge.modified">     <Setter Property="Background" Value="#3a2e16" /></Style>
        <Style Selector="Border.kindBadge > TextBlock">
            <Setter Property="Foreground" Value="#9cdcfe" />
        </Style>
        <Style Selector="Border.kindBadge.added > TextBlock">    <Setter Property="Foreground" Value="#a0e8b0" /></Style>
        <Style Selector="Border.kindBadge.deleted > TextBlock">  <Setter Property="Foreground" Value="#f3a0a0" /></Style>
        <Style Selector="Border.kindBadge.modified > TextBlock"> <Setter Property="Foreground" Value="#fdd58c" /></Style>

        <Style Selector="TextBlock.entryKey.added">    <Setter Property="Foreground" Value="#a0e8b0" /></Style>
        <Style Selector="TextBlock.entryKey.deleted">  <Setter Property="Foreground" Value="#f3a0a0" /></Style>
        <Style Selector="TextBlock.entryKey.modified"> <Setter Property="Foreground" Value="#fdd58c" /></Style>
    </Window.Styles>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#141414" Padding="12,10" BorderBrush="#2a2a2a" BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#3a2e16" BorderBrush="#a87a33" BorderThickness="1" CornerRadius="3"
                            Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="LEGACY" FontSize="10" FontWeight="SemiBold" Foreground="#fdd58c" />
                    </Border>
                    <TextBlock Text="Current:" Foreground="#888" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentBranch}" FontFamily="Cascadia Mono,Consolas"
                               Foreground="#9cdcfe" VerticalAlignment="Center" />
                    <TextBlock Text=" ↔ " Foreground="#666" VerticalAlignment="Center" />
                    <TextBlock Text="Compare:" Foreground="#888" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding AvailableBranches}"
                              SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                              MinWidth="220" />
                    <Button Classes="primary" Content="Load snapshot"
                            Command="{Binding LoadSnapshotCommand}"
                            IsEnabled="{Binding !IsLoading}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="#aaa" FontSize="11" />
                <TextBlock Text="{Binding SnapshotWarningText}" Foreground="#fdd58c" FontSize="11"
                           IsVisible="{Binding SnapshotWarningText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="320,3,*">
            <!-- Entry list -->
            <Border Grid.Column="0" Background="#181818" BorderBrush="#2a2a2a" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="10,8" Spacing="6">
                        <TextBlock Text="Entries" FontWeight="SemiBold" Foreground="#ddd" />
                        <TextBox Text="{Binding EntryFilter, Mode=TwoWay}" Watermark="Filter…" />
                        <CheckBox Content="Show changed only"
                                  IsChecked="{Binding ShowChangedOnly, Mode=TwoWay}"
                                  FontSize="11" Foreground="#bbb" />
                        <!-- Summary chips — click-to-filter could be a later upgrade; for
                             now they're a read-only glance at what's in the snapshot. -->
                        <WrapPanel>
                            <Border Background="#1e3a22" CornerRadius="3" Padding="6,1" Margin="0,0,4,2">
                                <TextBlock Foreground="#a0e8b0" FontSize="10">
                                    <Run Text="+ " /><Run Text="{Binding AddedCount}" />
                                </TextBlock>
                            </Border>
                            <Border Background="#3a1e1e" CornerRadius="3" Padding="6,1" Margin="0,0,4,2">
                                <TextBlock Foreground="#f3a0a0" FontSize="10">
                                    <Run Text="− " /><Run Text="{Binding DeletedCount}" />
                                </TextBlock>
                            </Border>
                            <Border Background="#3a2e16" CornerRadius="3" Padding="6,1" Margin="0,0,4,2">
                                <TextBlock Foreground="#fdd58c" FontSize="10">
                                    <Run Text="~ " /><Run Text="{Binding ModifiedCount}" />
                                </TextBlock>
                            </Border>
                            <Border Background="#2a2a2a" CornerRadius="3" Padding="6,1" Margin="0,0,0,2">
                                <TextBlock Foreground="#888" FontSize="10">
                                    <Run Text="= " /><Run Text="{Binding UnchangedCount}" />
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding FilteredEntries}" Padding="6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vml:LegacyDiffEntry">
                                    <Button Classes="entryBtn" Tag="{Binding}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Classes="kindBadge"
                                                    Classes.added="{Binding IsAdded}"
                                                    Classes.deleted="{Binding IsDeleted}"
                                                    Classes.modified="{Binding IsModified}">
                                                <TextBlock Text="{Binding KindLabel}" FontSize="10" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Key}" VerticalAlignment="Center"
                                                       Classes="entryKey"
                                                       Classes.added="{Binding IsAdded}"
                                                       Classes.deleted="{Binding IsDeleted}"
                                                       Classes.modified="{Binding IsModified}"
                                                       FontFamily="Cascadia Mono,Consolas" FontSize="12" />
                                            <TextBlock Grid.Column="2" Text="{Binding PresenceTag}" VerticalAlignment="Center"
                                                       FontSize="10" Foreground="#888" Margin="6,0,0,0" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="#2a2a2a" ResizeDirection="Columns" />

            <!-- Diff rows -->
            <Border Grid.Column="2" Background="#1c1c1c">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#141414" Padding="12,6"
                            BorderBrush="#2a2a2a" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="220,*,*">
                            <TextBlock Grid.Column="0" Foreground="#888" FontSize="11" VerticalAlignment="Center">
                                <Run Text="Property" />
                                <Run Text="  ·  diffs: " Foreground="#666" />
                                <Run Text="{Binding DifferCount}" Foreground="#fdd58c" />
                            </TextBlock>
                            <TextBlock Grid.Column="1" Text="{Binding LeftHeading}" FontWeight="SemiBold"
                                       Foreground="#9cdcfe" VerticalAlignment="Center" Padding="8,0" />
                            <TextBlock Grid.Column="2" Text="{Binding RightHeading}" FontWeight="SemiBold"
                                       Foreground="#9cdcfe" VerticalAlignment="Center" Padding="8,0" />
                        </Grid>
                    </Border>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Rows}" Padding="6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vml:LegacyDiffRow">
                                    <Border Classes="diffRow" Classes.differs="{Binding Differs}">
                                        <Grid ColumnDefinitions="220,*,*">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Label}" Foreground="#9cdcfe" FontWeight="SemiBold" FontSize="12" />
                                                <TextBlock Text="{Binding PropertyKey}" Foreground="#666" FontSize="10"
                                                           FontFamily="Cascadia Mono,Consolas" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,4,0">
                                                <TextBlock Text="{Binding LeftValue}" Classes="valueCell" Classes.differs="{Binding Differs}" />
                                                <TextBlock Text="{Binding LeftSource}" Foreground="#666" FontSize="10" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                                <TextBlock Text="{Binding RightValue}" Classes="valueCell" Classes.differs="{Binding Differs}" />
                                                <TextBlock Text="{Binding RightSource}" Foreground="#666" FontSize="10" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
