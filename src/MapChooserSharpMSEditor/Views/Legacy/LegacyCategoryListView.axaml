<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmel="using:MapChooserSharpMSEditor.ViewModels.Editors.Legacy"
             xmlns:mlegacy="using:MapChooserSharpMSEditor.Models.Legacy"
             xmlns:l="using:MapChooserSharpMSEditor.Services"
             x:Class="MapChooserSharpMSEditor.Views.Legacy.LegacyCategoryListView"
             x:DataType="vmel:LegacyCategoryListViewModel">
    <UserControl.Styles>
        <Style Selector="Button.entry">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding Heading}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding File.DisplayName, StringFormat='({0})'}" Foreground="#888" VerticalAlignment="Center" />
            <Border Background="#3a2e16" BorderBrush="#a87a33" BorderThickness="1" CornerRadius="3"
                    Padding="6,2" VerticalAlignment="Center">
                <TextBlock Text="LEGACY" FontSize="11" FontWeight="SemiBold" Foreground="#fdd58c" />
            </Border>
            <Button Content="{l:Localize Button.AddEntry}" Margin="12,0,0,0" Command="{Binding AddEntryCommand}" />
        </StackPanel>

        <TextBox Watermark="{l:Localize Watermark.Search}" Text="{Binding Filter, Mode=TwoWay}" Width="360" HorizontalAlignment="Left" />

        <Border Background="#1e1e1e" Padding="10" CornerRadius="4">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.DataTemplates>
                        <DataTemplate DataType="mlegacy:LegacyMapEntry">
                            <Button Classes="entry"
                                    Command="{Binding $parent[ItemsControl].((vmel:LegacyCategoryListViewModel)DataContext).OpenCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="&#xE707;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                               Foreground="#7aa2f7" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding MapName}" FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center" />
                                    <TextBlock Foreground="#888" FontSize="11" VerticalAlignment="Center"
                                               Text="{Binding Properties.MapNameAlias, StringFormat={l:Localize Overview.MapAliasFormat}}"
                                               IsVisible="{Binding Properties.HasMapNameAlias}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                        <DataTemplate DataType="mlegacy:LegacyGroupEntry">
                            <Button Classes="entry"
                                    Command="{Binding $parent[ItemsControl].((vmel:LegacyCategoryListViewModel)DataContext).OpenCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                               Foreground="#7aa2f7" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding GroupName}" FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.DataTemplates>
                </ItemsControl>
                <TextBlock Text="{Binding EmptyText}" Foreground="#666" FontStyle="Italic"
                           IsVisible="{Binding !Entries.Count}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
