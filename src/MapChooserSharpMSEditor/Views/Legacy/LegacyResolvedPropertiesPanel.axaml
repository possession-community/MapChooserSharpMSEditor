<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vml="using:MapChooserSharpMSEditor.ViewModels.Legacy"
             xmlns:slegacy="using:MapChooserSharpMSEditor.Services.Legacy"
             xmlns:l="using:MapChooserSharpMSEditor.Services"
             x:Class="MapChooserSharpMSEditor.Views.Legacy.LegacyResolvedPropertiesPanel"
             x:DataType="vml:LegacyResolvedPropertiesViewModel">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#141414" Padding="10,8">
            <StackPanel Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Heading}" FontWeight="SemiBold" Foreground="#ddd" />
                    <Border Background="#3a2e16" BorderBrush="#a87a33" BorderThickness="1" CornerRadius="3"
                            Padding="4,1" VerticalAlignment="Center">
                        <TextBlock Text="LEGACY" FontSize="9" FontWeight="SemiBold" Foreground="#fdd58c" />
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding ContextLine}" Foreground="#888" FontSize="11" />
            </StackPanel>
        </Border>
        <ScrollViewer>
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Rows}" Padding="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="slegacy:LegacyPropertyResolver+ResolvedRow">
                            <Border Background="#1e1e1e" Margin="2" Padding="6,4" CornerRadius="3">
                                <StackPanel Spacing="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="#9cdcfe" />
                                            <TextBlock Text="{Binding Property}" Foreground="#666" FontSize="10"
                                                       FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Bottom" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Source}" FontSize="10"
                                                   Foreground="#888" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="{Binding DisplayValue}" FontFamily="Cascadia Mono,Consolas"
                                               FontSize="12" Foreground="#e0e0e0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel IsVisible="{Binding HasExtraSections}" Margin="4,8,4,4" Spacing="4">
                    <TextBlock Text="{l:Localize Resolved.ExtrasHeading}" FontWeight="SemiBold"
                               Foreground="#bbb" FontSize="12" Margin="2,0,0,0" />
                    <ItemsControl ItemsSource="{Binding ExtraSections}" HorizontalAlignment="Stretch">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="slegacy:LegacyPropertyResolver+ResolvedExtraSection">
                                <Expander Margin="0,0,0,4" IsExpanded="False"
                                          Background="#1e1e1e" Foreground="#ddd"
                                          HorizontalAlignment="Stretch">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       FontFamily="Cascadia Mono,Consolas" Foreground="#9cdcfe" />
                                            <TextBlock Text="{Binding Entries.Count, StringFormat=({0})}"
                                                       Foreground="#666" FontSize="11" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel Grid.IsSharedSizeScope="True">
                                        <Grid Margin="4,2,4,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="lexKey" />
                                                <ColumnDefinition Width="*"    SharedSizeGroup="lexVal" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="lexSrc" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{l:Localize Resolved.Extras.Key}"
                                                       Foreground="#666" FontSize="10" Padding="4,0" />
                                            <TextBlock Grid.Column="1" Text="{l:Localize Resolved.Extras.Value}"
                                                       Foreground="#666" FontSize="10" Padding="4,0" />
                                            <TextBlock Grid.Column="2" Text="{l:Localize Resolved.Extras.Source}"
                                                       Foreground="#666" FontSize="10" Padding="4,0" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Entries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="slegacy:LegacyPropertyResolver+ResolvedExtraEntry">
                                                    <Grid Margin="4,1" Background="#181818">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="lexKey" />
                                                            <ColumnDefinition Width="*"    SharedSizeGroup="lexVal" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="lexSrc" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                                   FontFamily="Cascadia Mono,Consolas"
                                                                   Foreground="#e0e0e0" FontSize="12"
                                                                   Padding="4,2" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                                   FontFamily="Cascadia Mono,Consolas"
                                                                   Foreground="#e0e0e0" FontSize="12"
                                                                   TextWrapping="Wrap" Padding="4,2"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Source}"
                                                                   ToolTip.Tip="{Binding Source}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="#888" FontSize="11"
                                                                   Padding="4,2" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
