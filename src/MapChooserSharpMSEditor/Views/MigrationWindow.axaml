<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MapChooserSharpMSEditor.ViewModels"
        xmlns:l="using:MapChooserSharpMSEditor.Services"
        xmlns:svc="using:MapChooserSharpMSEditor.Services"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="MapChooserSharpMSEditor.Views.MigrationWindow"
        x:DataType="vm:MigrationViewModel"
        Title="{l:Localize Migration.Title}"
        Width="960" Height="720"
        MinWidth="800" MinHeight="500">

    <DockPanel Margin="16">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="{l:Localize Migration.Title}"
                   FontSize="20" FontWeight="Bold" Foreground="#ddd" Margin="0,0,0,12" />
        <TextBlock DockPanel.Dock="Top" Text="{l:Localize Migration.Description}"
                   Foreground="#aaa" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16" />

        <!-- Schema diff summary -->
        <Border DockPanel.Dock="Top" Background="#1e1e1e" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*">
                <!-- Removed properties -->
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{l:Localize Migration.Removed}" FontWeight="SemiBold" Foreground="#f48771" FontSize="14" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding RemovedProperties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="-" Foreground="#f48771" FontFamily="Cascadia Mono,Consolas" />
                                    <TextBlock Text="{Binding}" Foreground="#f48771" FontFamily="Cascadia Mono,Consolas" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Added properties -->
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{l:Localize Migration.Added}" FontWeight="SemiBold" Foreground="#89d185" FontSize="14" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding AddedProperties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="+" Foreground="#89d185" FontFamily="Cascadia Mono,Consolas" />
                                    <TextBlock Text="{Binding}" Foreground="#89d185" FontFamily="Cascadia Mono,Consolas" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Source folder picker -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="{l:Localize Migration.BrowseSource}" Command="{Binding BrowseSourceCommand}" />
        </StackPanel>

        <!-- Status bar at bottom -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#aaa" FontSize="12" />
        </Border>

        <!-- Output + migrate controls at bottom -->
        <Border DockPanel.Dock="Bottom" Padding="0,8" Margin="0,8,0,0"
                BorderBrush="#2a2a2a" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,8,0,0">
                <TextBlock Grid.Column="0" Text="{l:Localize Migration.OutputFolder}" VerticalAlignment="Center" Foreground="#aaa" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding OutputFolder}" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="{l:Localize Migration.BrowseOutput}" Command="{Binding BrowseOutputCommand}" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="{l:Localize Migration.Execute}" Command="{Binding ExecuteMigrationCommand}"
                        IsEnabled="{Binding CanMigrate}"
                        Background="#2d5a2d" Foreground="White" FontWeight="SemiBold" Padding="16,6" />
            </Grid>
        </Border>

        <!-- File list -->
        <Border Background="#181818" CornerRadius="4" Padding="4" IsVisible="{Binding HasResults}">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Files}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:MigrationFileViewModel">
                            <Border Background="#1e1e1e" Margin="2,2" Padding="12,8" CornerRadius="4">
                                <StackPanel Spacing="4">
                                    <!-- File name + stats -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding RelativePath}"
                                                   FontFamily="Cascadia Mono,Consolas" FontSize="13" Foreground="#ddd" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                            <TextBlock FontSize="11" Foreground="#888">
                                                <Run Text="Groups:" /><Run Text="{Binding GroupCount}" />
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="#888">
                                                <Run Text="Maps:" /><Run Text="{Binding MapCount}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Removed values from this file -->
                                    <ItemsControl ItemsSource="{Binding RemovedChanges}" IsVisible="{Binding RemovedCount}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="svc:MigrationChange">
                                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="16,1,0,1">
                                                    <Border Background="#3a1e1e" CornerRadius="3" Padding="4,1">
                                                        <TextBlock Text="{Binding Property}" FontSize="11" Foreground="#f48771"
                                                                   FontFamily="Cascadia Mono,Consolas" />
                                                    </Border>
                                                    <TextBlock Text="=" Foreground="#666" FontSize="11" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding OldValue}" FontSize="11" Foreground="#888"
                                                               FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
