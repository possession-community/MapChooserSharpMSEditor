<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vme="using:MapChooserSharpMSEditor.ViewModels.Editors"
             xmlns:sys="using:System"
             xmlns:models="using:MapChooserSharpMSEditor.Models"
             xmlns:views="using:MapChooserSharpMSEditor.Views"
             xmlns:l="using:MapChooserSharpMSEditor.Services"
             x:Class="MapChooserSharpMSEditor.Views.OverrideEditorView"
             x:DataType="vme:OverrideEditorViewModel">
    <UserControl.Resources>
        <views:CollectionJoinConverter x:Key="Join" />
    </UserControl.Resources>
    <UserControl.Styles>
        <!-- Same "selected day" blue treatment as the PropertySetView DaysAllowed chips
             so the override's trigger block visually matches. -->
        <Style Selector="ToggleButton.dayChip:checked">
            <Setter Property="Background" Value="#2a5fa8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#3c7bd4" />
        </Style>
        <Style Selector="ToggleButton.dayChip:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3470c8" />
        </Style>
    </UserControl.Styles>
    <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="&#xE787;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                       FontSize="22" Foreground="#7aa2f7" VerticalAlignment="Center" />
            <TextBlock Text="{l:Localize Editor.Override}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBox Text="{Binding Override.Name}" Width="300" VerticalAlignment="Center" FontFamily="Cascadia Mono,Consolas" />
        </StackPanel>
        <TextBlock Text="{Binding ParentDisplay}" Foreground="#888" FontFamily="Cascadia Mono,Consolas" />
        <TextBlock Text="{Binding File.DisplayName, StringFormat={l:Localize Label.FilePrefix}}" Foreground="#888" />

        <Separator />

        <!-- Override trigger definition -->
        <Border Padding="12" Background="#1e1e1e" CornerRadius="4">
            <StackPanel Spacing="10">
                <TextBlock Text="{l:Localize Override.Trigger}" FontWeight="SemiBold" Foreground="#9cdcfe" />
                <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Localize Override.Enabled}" VerticalAlignment="Center" />
                    <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding Override.Enabled}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Localize Override.ForceOverride}" VerticalAlignment="Center" />
                    <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding Override.ForceOverride}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{l:Localize Override.OverridePriority}" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Override.OverridePriority}" FormatString="0" />
                </Grid>

                <TextBlock Text="{l:Localize Override.TargetDays}" FontWeight="SemiBold" Foreground="#9cdcfe" Margin="0,8,0,0" />
                <ItemsControl ItemsSource="{Binding TargetDayToggles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vme:DayToggleViewModel">
                            <ToggleButton Classes="dayChip" Content="{Binding Day}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          MinWidth="90" Margin="0,0,4,4" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Foreground="#888" FontSize="12"
                           Text="{Binding Override.TargetDays, Converter={StaticResource Join}, StringFormat={l:Localize Override.SelectedDays}}" />

                <TextBlock Text="{l:Localize Override.TargetTimeRanges}" FontWeight="SemiBold" Foreground="#9cdcfe" Margin="0,8,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBox x:Name="NewRangeBox" Width="180" Watermark="{l:Localize Watermark.TimeRange}"
                             TextChanged="OnNewRangeTextChanged" />
                    <Button Content="{l:Localize Button.Add}" Click="OnAddTargetTimeRange" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding Override.TargetTimeRanges}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:TimeRangeSpec">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="×" Padding="6,2"
                                        Tag="{Binding}" Click="OnRemoveTargetTimeRange" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <TextBlock Text="{l:Localize Override.OverriddenProps}"
                   FontSize="14" FontWeight="SemiBold" Foreground="#9cdcfe" Margin="0,16,0,0" />
        <views:PropertySetView DataContext="{Binding Properties}" />
    </StackPanel>
</UserControl>
