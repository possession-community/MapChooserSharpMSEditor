<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MapChooserSharpMSEditor.ViewModels"
        xmlns:vme="using:MapChooserSharpMSEditor.ViewModels.Editors"
        xmlns:vmt="using:MapChooserSharpMSEditor.ViewModels.TreeNodes"
        xmlns:views="using:MapChooserSharpMSEditor.Views"
        xmlns:viewsl="using:MapChooserSharpMSEditor.Views.Legacy"
        xmlns:vmel="using:MapChooserSharpMSEditor.ViewModels.Editors.Legacy"
        xmlns:l="using:MapChooserSharpMSEditor.Services"
        xmlns:svc="using:MapChooserSharpMSEditor.Services"
        xmlns:models="using:MapChooserSharpMSEditor.Models"
        xmlns:mlegacy="using:MapChooserSharpMSEditor.Models.Legacy"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="MapChooserSharpMSEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{l:Localize App.Title}"
        Width="1640" Height="800"
        MinWidth="1640" MinHeight="600">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoActionCommand}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoActionCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Z" Command="{Binding RedoActionCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
        <KeyBinding Gesture="Ctrl+F" Command="{Binding OpenSearchCommand}" />
        <KeyBinding Gesture="Ctrl+F" Command="{Binding OpenLegacySearchCommand}" />
    </Window.KeyBindings>

    <Window.Resources>
        <!-- Editor DataTemplates: render the active editor VM by its type. -->
        <DataTemplate x:Key="WelcomeTemplate" DataType="vme:WelcomeViewModel">
            <views:WelcomeView />
        </DataTemplate>
        <DataTemplate x:Key="DefaultTemplate" DataType="vme:DefaultSettingsViewModel">
            <views:DefaultSettingsView />
        </DataTemplate>
        <DataTemplate x:Key="MapTemplate" DataType="vme:MapEditorViewModel">
            <views:MapEditorView />
        </DataTemplate>
        <DataTemplate x:Key="GroupTemplate" DataType="vme:GroupEditorViewModel">
            <views:GroupEditorView />
        </DataTemplate>
        <DataTemplate x:Key="OverrideTemplate" DataType="vme:OverrideEditorViewModel">
            <views:OverrideEditorView />
        </DataTemplate>
    </Window.Resources>

    <Window.DataTemplates>
        <DataTemplate DataType="vme:WelcomeViewModel">
            <views:WelcomeView />
        </DataTemplate>
        <DataTemplate DataType="vme:DefaultSettingsViewModel">
            <views:DefaultSettingsView />
        </DataTemplate>
        <DataTemplate DataType="vme:MapEditorViewModel">
            <views:MapEditorView />
        </DataTemplate>
        <DataTemplate DataType="vme:GroupEditorViewModel">
            <views:GroupEditorView />
        </DataTemplate>
        <DataTemplate DataType="vme:OverrideEditorViewModel">
            <views:OverrideEditorView />
        </DataTemplate>
        <DataTemplate DataType="vme:FileOverviewViewModel">
            <views:FileOverviewView />
        </DataTemplate>
        <DataTemplate DataType="vme:CategoryListViewModel">
            <views:CategoryListView />
        </DataTemplate>
        <!-- Legacy editor templates -->
        <DataTemplate DataType="vmel:LegacyMapEditorViewModel">
            <viewsl:LegacyMapEditorView />
        </DataTemplate>
        <DataTemplate DataType="vmel:LegacyGroupEditorViewModel">
            <viewsl:LegacyGroupEditorView />
        </DataTemplate>
        <DataTemplate DataType="vmel:LegacyDefaultSettingsViewModel">
            <viewsl:LegacyDefaultSettingsView />
        </DataTemplate>
        <DataTemplate DataType="vmel:LegacyFileOverviewViewModel">
            <viewsl:LegacyFileOverviewView />
        </DataTemplate>
        <DataTemplate DataType="vmel:LegacyCategoryListViewModel">
            <viewsl:LegacyCategoryListView />
        </DataTemplate>
    </Window.DataTemplates>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{l:Localize Menu.File}">
                <MenuItem Header="{l:Localize Menu.File.New}" Command="{Binding NewFileCommand}" InputGesture="Ctrl+N" />
                <MenuItem Header="{l:Localize Menu.File.OpenFile}" Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O" />
                <MenuItem Header="{l:Localize Menu.File.OpenFolder}" Command="{Binding OpenFolderCommand}" />
                <Separator />
                <MenuItem Header="{l:Localize Menu.File.Save}" Command="{Binding SaveCommand}" InputGesture="Ctrl+S" />
                <MenuItem Header="{l:Localize Menu.File.SaveAs}" Command="{Binding SaveAsCommand}" InputGesture="Ctrl+Shift+S" />
                <MenuItem Header="{l:Localize Menu.File.SaveAll}" Command="{Binding SaveAllCommand}" />
                <Separator />
                <MenuItem Header="{l:Localize Menu.File.Close}" Command="{Binding CloseFileCommand}" />
                <MenuItem Header="{l:Localize Menu.File.CloseAll}" Command="{Binding CloseAllCommand}" />
                <Separator />
                <MenuItem Header="{l:Localize Menu.File.Mode}">
                    <MenuItem Header="{l:Localize Menu.File.Mode.Current}"
                              Command="{Binding SwitchModeCommand}" CommandParameter="Current"
                              ToggleType="Radio" GroupName="appMode"
                              IsChecked="{Binding IsCurrentMode}" />
                    <MenuItem Header="{l:Localize Menu.File.Mode.Legacy}"
                              Command="{Binding SwitchModeCommand}" CommandParameter="Legacy"
                              ToggleType="Radio" GroupName="appMode"
                              IsChecked="{Binding IsLegacyMode}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{l:Localize Menu.Edit}">
                <MenuItem Header="{l:Localize Menu.Edit.Undo}" Command="{Binding UndoActionCommand}" InputGesture="Ctrl+Z" />
                <MenuItem Header="{l:Localize Menu.Edit.Redo}" Command="{Binding RedoActionCommand}" InputGesture="Ctrl+Y" />
                <Separator />
                <MenuItem Header="{l:Localize Menu.Edit.Find}" Command="{Binding OpenSearchCommand}" InputGesture="Ctrl+F"
                          IsVisible="{Binding IsCurrentMode}" />
                <MenuItem Header="{l:Localize Menu.Edit.Find}" Command="{Binding OpenLegacySearchCommand}" InputGesture="Ctrl+F"
                          IsVisible="{Binding IsLegacyMode}" />
                <Separator />
                <MenuItem Header="{l:Localize Menu.Edit.AddMap}" Command="{Binding AddMapCommand}" />
                <MenuItem Header="{l:Localize Menu.Edit.AddGroup}" Command="{Binding AddGroupCommand}" />
            </MenuItem>
            <MenuItem Header="{l:Localize Menu.Tools}">
                <MenuItem Header="{l:Localize Menu.Tools.WorkshopCheck}"
                          Command="{Binding OpenWorkshopCheckCommand}"
                          IsVisible="{Binding IsCurrentMode}" />
                <MenuItem Header="{l:Localize Menu.Tools.WorkshopCheck}"
                          Command="{Binding OpenLegacyWorkshopCheckCommand}"
                          IsVisible="{Binding IsLegacyMode}" />
            </MenuItem>
            <MenuItem Header="{l:Localize Menu.View}">
                <!-- Locales are listed explicitly because MenuItem's ItemTemplate nests a
                     second MenuItem inside the generated container, which swallows clicks.
                     New locale = one more line here + one entry in Localization.cs. -->
                <MenuItem Header="{l:Localize Menu.View.Language}">
                    <MenuItem Header="English"
                              Command="{Binding SelectLanguageCommand}" CommandParameter="en" />
                    <MenuItem Header="日本語"
                              Command="{Binding SelectLanguageCommand}" CommandParameter="ja" />
                </MenuItem>
                <MenuItem Header="{l:Localize Menu.View.DebugConsole}"
                          Command="{Binding ToggleDebugConsoleCommand}" />
            </MenuItem>
        </Menu>

        <!-- Inline quick-search strip. Always visible just under the menu bar; typing filters
             live, Enter jumps to the top match, clicking a row navigates and clears the query.
             Ctrl+F still opens the full-featured Search window for advanced filters. -->
        <Border DockPanel.Dock="Top" Background="#181818" BorderBrush="#2a2a2a"
                BorderThickness="0,0,0,1" Padding="10,6">
            <Grid ColumnDefinitions="Auto,400,*,Auto">
                <!-- Current mode: bound to Search VM -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding IsCurrentMode}">
                    <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                               FontSize="14" Foreground="#888" VerticalAlignment="Center" Margin="2,0,4,0" />
                    <TextBox Width="380" Text="{Binding Search.Query, Mode=TwoWay}"
                             Watermark="{l:Localize Search.Watermark}"
                             FontSize="12">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding Search.OpenInlineTopCommand}" />
                            <KeyBinding Gesture="Escape" Command="{Binding Search.ClearQueryCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                </StackPanel>
                <!-- Legacy mode: bound to LegacySearch VM -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding IsLegacyMode}">
                    <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                               FontSize="14" Foreground="#888" VerticalAlignment="Center" Margin="2,0,4,0" />
                    <TextBox Width="380" Text="{Binding LegacySearch.Query, Mode=TwoWay}"
                             Watermark="{l:Localize Search.Watermark}"
                             FontSize="12">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding LegacySearch.OpenInlineTopCommand}" />
                            <KeyBinding Gesture="Escape" Command="{Binding LegacySearch.ClearQueryCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                </StackPanel>
                <TextBlock Grid.Column="3" Text="{l:Localize Search.InlineHint}"
                           Foreground="#666" FontSize="11" VerticalAlignment="Center" Margin="8,0,2,0" />
            </Grid>
        </Border>

        <!-- Result dropdown for inline search. Docked just below the bar; appears only when
             the user has typed something AND there are matches. Click a row to navigate. -->
        <Border DockPanel.Dock="Top" Background="#1a1a1a" BorderBrush="#3a3a3a"
                BorderThickness="0,0,0,1" MaxHeight="280"
                IsVisible="{Binding Search.HasResults}">
            <StackPanel IsVisible="{Binding IsCurrentMode}">
                <ScrollViewer MaxHeight="280">
                    <ItemsControl ItemsSource="{Binding Search.Results}" Padding="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:SearchResult">
                                <Button HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0" Padding="10,4"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Search.OpenInlineCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Background="#2a3148" CornerRadius="3"
                                                Padding="6,1" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Kind}" FontSize="10" Foreground="#9cdcfe" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                   FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center" FontSize="12" />
                                        <TextBlock Grid.Column="2" Text="{Binding FileName}" FontSize="11"
                                                   Foreground="#666" VerticalAlignment="Center" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="#1a1a1a" BorderBrush="#3a3a3a"
                BorderThickness="0,0,0,1" MaxHeight="280"
                IsVisible="{Binding LegacySearch.HasResults}">
            <StackPanel IsVisible="{Binding IsLegacyMode}">
                <ScrollViewer MaxHeight="280">
                    <ItemsControl ItemsSource="{Binding LegacySearch.Results}" Padding="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="mlegacy:LegacySearchResult">
                                <Button HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0" Padding="10,4"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LegacySearch.OpenInlineCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Background="#2a3148" CornerRadius="3"
                                                Padding="6,1" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Kind}" FontSize="10" Foreground="#9cdcfe" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                   FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center" FontSize="12" />
                                        <TextBlock Grid.Column="2" Text="{Binding FileName}" FontSize="11"
                                                   Foreground="#666" VerticalAlignment="Center" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#1f1f1f" Padding="8,3">
            <TextBlock Text="{Binding StatusText}" Foreground="#bbb" FontSize="12" />
        </Border>

        <!-- Debug console: toggleable via View → Debug Console. Sits above the status bar
             so it doesn't eat into the main editor area unless the user opens it. -->
        <Border DockPanel.Dock="Bottom" Height="200" BorderBrush="#2a2a2a"
                BorderThickness="0,1,0,0" IsVisible="{Binding IsDebugConsoleVisible}">
            <views:DebugConsolePanel />
        </Border>

        <!-- Legacy mode banner: persistent reminder that the loaded files use the older
             MapChooserSharp.API schema. Sits above the status bar so it's visible on every
             screen until the user switches back to Current. -->
        <Border DockPanel.Dock="Top" Background="#3a2e16" BorderBrush="#a87a33"
                BorderThickness="0,0,0,1" Padding="12,4"
                IsVisible="{Binding IsLegacyMode}">
            <TextBlock Text="{l:Localize Mode.Banner}" Foreground="#fdd58c" FontSize="12" />
        </Border>

        <!-- Section-collision banner: shows above the status bar whenever any section path
             exists in more than one loaded file. Server would reject this on concat-parse. -->
        <Border DockPanel.Dock="Bottom" Background="#3a1e1e" BorderBrush="#a33"
                BorderThickness="0,1,0,1" Padding="12,6"
                IsVisible="{Binding Project.HasSectionCollisions}">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Banner.SectionCollisions}" FontWeight="SemiBold" Foreground="#fbb" />
                <ItemsControl ItemsSource="{Binding Project.SectionCollisions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="11" Foreground="#fdd" FontFamily="Cascadia Mono,Consolas">
                                <Run Text="[" /><Run Text="{Binding Path}" /><Run Text="] " />
                                <Run Text="→" Foreground="#fbb" />
                                <Run Text=" " />
                                <Run Text="{Binding Owners, Converter={x:Static views:CollectionJoinConverter.Instance}}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Legacy section-collision banner: same UX as Current, parallel binding. -->
        <Border DockPanel.Dock="Bottom" Background="#3a1e1e" BorderBrush="#a33"
                BorderThickness="0,1,0,1" Padding="12,6"
                IsVisible="{Binding LegacyProject.HasSectionCollisions}">
            <StackPanel Spacing="4">
                <TextBlock Text="{l:Localize Banner.SectionCollisions}" FontWeight="SemiBold" Foreground="#fbb" />
                <ItemsControl ItemsSource="{Binding LegacyProject.SectionCollisions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="11" Foreground="#fdd" FontFamily="Cascadia Mono,Consolas">
                                <Run Text="[" /><Run Text="{Binding Path}" /><Run Text="] " />
                                <Run Text="→" Foreground="#fbb" />
                                <Run Text=" " />
                                <Run Text="{Binding Owners, Converter={x:Static views:CollectionJoinConverter.Instance}}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Sidebar + content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left sidebar -->
            <Border Grid.Column="0" Background="#181818" BorderBrush="#2a2a2a" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="10,8" Background="#141414">
                        <TextBlock Text="{l:Localize Sidebar.Header}" FontWeight="SemiBold" Foreground="#ddd" />
                    </Border>
                    <TreeView x:Name="MainTree"
                              ItemsSource="{Binding Tree}"
                              SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                              SelectionChanged="OnTreeSelectionChanged">
                        <!-- Binds each TreeViewItem's IsExpanded to the VM node's flag so
                             programmatic expansion (e.g. search navigation) actually shows. -->
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem" x:DataType="vmt:TreeNodeBase">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.Styles>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate DataType="vmt:TreeNodeBase" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <!-- Right-click: "Remove from view". The command lives on
                                         MainWindowViewModel so we reach it via the TreeView's
                                         ancestor DataContext; CommandParameter is the node
                                         itself so the handler knows whether it's a file or
                                         folder. MenuItem is hidden for the structural nodes
                                         (Default/Category/Map/Group/Override) since removing
                                         those from view doesn't correspond to a real action. -->
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{l:Localize ContextMenu.RemoveFromView}"
                                                      Command="{Binding $parent[TreeView].((vm:MainWindowViewModel)DataContext).RemoveFromViewCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding Converter={x:Static views:IsFileOrFolderNodeConverter.Instance}}" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <TextBlock Text="{Binding Icon}"
                                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="#7aa2f7"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Title}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="#2a2a2a" ResizeDirection="Columns" />

            <!-- Middle: editor, with optional right-hand Resolved panel docked inside. -->
            <DockPanel Grid.Column="2">
                <!-- Thin toggle strip on the right edge, always present so the panel can be
                     reopened after collapsing. -->
                <Border DockPanel.Dock="Right" Width="24" Background="#151515"
                        BorderBrush="#2a2a2a" BorderThickness="1,0,0,0">
                    <Button Command="{Binding ToggleResolvedPanelCommand}"
                            Padding="0" Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Top" Margin="0,6,0,0"
                            ToolTip.Tip="{l:Localize Sidebar.ToggleResolved}">
                        <TextBlock Text="{Binding IsResolvedPanelVisible, Converter={x:Static views:BoolToArrowConverter.Instance}}"
                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#bbb"
                                   HorizontalAlignment="Center" />
                    </Button>
                </Border>

                <Border DockPanel.Dock="Right" Width="440" MinWidth="440" Background="#1a1a1a"
                        BorderBrush="#2a2a2a" BorderThickness="1,0,0,0"
                        IsVisible="{Binding IsResolvedPanelVisible}">
                    <Grid>
                        <views:ResolvedPropertiesPanel DataContext="{Binding Resolved}"
                                                       IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsCurrentMode}" />
                        <viewsl:LegacyResolvedPropertiesPanel DataContext="{Binding LegacyResolved}"
                                                              IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLegacyMode}" />
                    </Grid>
                </Border>

                <GridSplitter DockPanel.Dock="Right" Width="3" Background="#2a2a2a"
                              ResizeDirection="Columns" IsVisible="{Binding IsResolvedPanelVisible}" />

                <!-- MinWidth keeps the pane from collapsing below a usable size even when the
                     user drags the splitters to the extreme. HorizontalScrollBarVisibility is
                     Disabled so the ScrollViewer passes the viewport width down to children,
                     which lets the property-row Grid's "*" column stretch with the pane. -->
                <Border Background="#1c1c1c" MinWidth="717">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <ContentControl Content="{Binding CurrentEditor}" Margin="20" />
                    </ScrollViewer>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
