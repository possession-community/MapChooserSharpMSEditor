<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vme="using:MapChooserSharpMSEditor.ViewModels.Editors"
             x:Class="MapChooserSharpMSEditor.Views.WelcomeView"
             x:DataType="vme:WelcomeViewModel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxWidth="520"
                   Foreground="#aaa" TextAlignment="Center" />
    </StackPanel>
</UserControl>
